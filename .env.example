# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack Configuration (Kenyan Shillings)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# Resend Email Configuration
RESEND_API_KEY=re_your_api_key
# Where contact-form notification emails are sent (optional — if unset, the
# message is still saved to contact_messages, just no email fires)
CONTACT_NOTIFICATION_EMAIL=support@christech.co.ke

# NOTE: SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY,
# CONTACT_NOTIFICATION_EMAIL and PAYSTACK_SECRET_KEY above are also
# required by worker/index.ts (the Cloudflare Worker behind /api/contact,
# /api/newsletter, and /api/paystack/*). Since the Worker doesn't read
# .env, set them as Worker secrets/vars instead:
#   wrangler secret put SUPABASE_URL
#   wrangler secret put SUPABASE_SERVICE_ROLE_KEY
#   wrangler secret put RESEND_API_KEY
#   wrangler secret put CONTACT_NOTIFICATION_EMAIL
#   wrangler secret put PAYSTACK_SECRET_KEY
# ALLOWED_ORIGIN is already set as a plain [vars] entry in wrangler.toml.
#
# In the Paystack dashboard (Settings -> API Keys & Webhooks), set the
# webhook callback URL to:
#   https://mytherapist.christech.co.ke/api/paystack/webhook
# (This replaces the old supabase.co/functions/v1/paystack-webhook URL —
# payment handling moved from Supabase Edge Functions into this Worker.)

# App Configuration
NEXT_PUBLIC_APP_URL=https://mytherapist.christech.co.ke
# Where logged-in users are sent after a successful sign-in / email
# confirmation. Leave unset to use the built-in /dashboard page on this
# same site. Only set this if the dashboard is ever split into a separate
# app/subdomain deployment.
# NEXT_PUBLIC_APP_DASHBOARD_URL=https://app.mytherapist.christech.co.ke/dashboard
